# =============================================================
# aestima — variabili d'ambiente
# =============================================================
# Copia in ".env" / ".env.local" per lo sviluppo.
# Su Vercel: Project Settings → Environment Variables
#   (o: npx vercel env add DATABASE_URL / DIRECT_URL)
# -------------------------------------------------------------

# Chiave API Anthropic (Claude). NON committare il valore reale.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Supabase Postgres (pooler IPv4) ---
# Sostituisci [YOUR-PASSWORD] con la password del database Supabase.
# Transaction pooler → Prisma Client (runtime / Vercel)
DATABASE_URL="postgresql://postgres.xkofjgzaominsxrekyef:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session pooler → Prisma CLI (migrate / db push / introspect)
DIRECT_URL="postgresql://postgres.xkofjgzaominsxrekyef:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# Segreto per cookie di sessione (login company). Genera una stringa lunga casuale.
AUTH_SECRET=
