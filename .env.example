# =============================================================
# aestima demo — variabili d'ambiente
# =============================================================
# Copia questo file in ".env.local" per lo sviluppo locale.
# Su Vercel: imposta queste variabili in Project Settings → Environment Variables.
#
# NB: la demo funziona ANCHE senza chiave API (fallback a dati mock).
#     Impostando la chiave, l'analisi della richiesta usa davvero Claude.
# -------------------------------------------------------------

# Chiave API Anthropic (Claude). NON committare mai il valore reale.
# Ottienila su https://console.anthropic.com/
ANTHROPIC_API_KEY=

# (Opzionale) Modello Claude da usare. Default: claude-sonnet-4-5
ANTHROPIC_MODEL=claude-sonnet-4-5
